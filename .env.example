# Django
DJANGO_SECRET_KEY=change-me-genere-une-vraie-cle-en-prod
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=fitcoach
POSTGRES_USER=fitcoach
POSTGRES_PASSWORD=fitcoach
# En local hors Docker : localhost. Avec docker-compose : surchargé à "db".
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# API Anthropic (Claude) — ne jamais commiter la vraie clé
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
