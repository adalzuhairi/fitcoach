# Django
DJANGO_SECRET_KEY=change-me-genere-une-vraie-cle-en-prod
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Domaine du framework "sites" (utilisé par allauth pour les URL absolues).
DJANGO_SITE_DOMAIN=localhost:8000
DJANGO_SITE_NAME=FitCoach

# PostgreSQL
POSTGRES_DB=fitcoach
POSTGRES_USER=fitcoach
POSTGRES_PASSWORD=fitcoach
# En local hors Docker : localhost. Avec docker-compose : surchargé à "db".
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Alternative variable standard
DB_NAME=fitcoach
DB_USER=fitcoach
DB_PASSWORD=fitcoach
DB_HOST=localhost
DB_PORT=5432

# Activez cette option si vous voulez utiliser PostgreSQL en développement local
# et que vos identifiants sont correctement configurés.
DJANGO_USE_POSTGRES=False

# Redis
REDIS_URL=redis://localhost:6379/0
DJANGO_USE_REDIS=False

# E-mail (réinitialisation de mot de passe via allauth)
# En dev, laissez DJANGO_USE_SMTP=False : les e-mails s'affichent dans la console.
DJANGO_USE_SMTP=False
DJANGO_DEFAULT_FROM_EMAIL=no-reply@fitcoach.infotechno.eu

# API Anthropic (Claude) — ne jamais commiter la vraie clé
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
