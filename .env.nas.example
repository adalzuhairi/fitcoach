# ---------------------------------------------------------------------------
# Variables d'environnement — déploiement NAS Synology (DS713+, DSM 6.2).
# Copiez ce fichier en .env.nas et remplissez les vraies valeurs.
# NE JAMAIS committer .env.nas (il est dans .gitignore).
#
#   cp .env.nas.example .env.nas
#   docker-compose -f docker-compose.nas.yml --env-file .env.nas up -d
# ---------------------------------------------------------------------------

# --- Emplacement des données sur le NAS ----------------------------------
# Bind mounts visibles et sauvegardables depuis DSM (db, redis, media).
# Les sous-dossiers postgres/ redis/ media/ y seront créés (voir DEPLOIEMENT_NAS.md).
NAS_DATA=/volume1/docker/fitcoach

# --- Django --------------------------------------------------------------
# Générez une clé forte, ex :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=remplacez-par-une-vraie-cle-secrete

DJANGO_DEBUG=False

# Hôte servi par le reverse proxy DSM, via le DDNS Synology.
# Django strippe le port du Host : pas de :8443 ici.
DJANGO_ALLOWED_HOSTS=nasinfotechno.synology.me,localhost,127.0.0.1

# Domaine du framework "sites" (allauth — URL absolues, ex: reset password).
# ⚠️ AVEC le port :8443 (port non-standard exposé sur la box, comme la VM en :4443).
DJANGO_SITE_DOMAIN=nasinfotechno.synology.me:8443
DJANGO_SITE_NAME=FitCoach

# Origine de confiance pour la protection CSRF.
# ⚠️ AVEC le port :8443 : le navigateur envoie l'origine avec le port (non-standard),
# il DOIT donc figurer ici, sinon erreurs CSRF sur tous les formulaires.
DJANGO_CSRF_TRUSTED_ORIGINS=https://nasinfotechno.synology.me:8443

# Sécurité HTTPS — le reverse proxy DSM termine le TLS et transmet
# X-Forwarded-Proto (déjà exploité par SECURE_PROXY_SSL_HEADER dans settings.py).
# ⚠️ Si vous obtenez une boucle de redirection, vérifiez que le proxy DSM
# transmet bien X-Forwarded-Proto, ou passez DJANGO_SECURE_SSL_REDIRECT=False.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

# --- Base de données (PostgreSQL dans le conteneur "db") -----------------
POSTGRES_DB=fitcoach
POSTGRES_USER=fitcoach
POSTGRES_PASSWORD=remplacez-par-un-mot-de-passe-fort

# --- Redis (cache + sessions) --------------------------------------------
DJANGO_USE_REDIS=True

# --- API Anthropic (Claude) ---------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
