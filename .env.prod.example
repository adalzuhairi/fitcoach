# ---------------------------------------------------------------------------
# Variables d'environnement de PRODUCTION pour FitCoach.
# Copiez ce fichier en .env.prod et remplissez les vraies valeurs.
# NE JAMAIS committer .env.prod (il est dans .gitignore).
#
#   cp .env.prod.example .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# ---------------------------------------------------------------------------

# --- Django --------------------------------------------------------------
# Générez une clé forte, ex :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=remplacez-par-une-vraie-cle-secrete

DJANGO_DEBUG=False

# Domaine public (le port est ignoré ici : Django compare le Host sans le port).
DJANGO_ALLOWED_HOSTS=fitcoach.infotechno.eu,localhost,127.0.0.1

# Domaine du framework "sites" (allauth — URL absolues, ex: reset password).
# Inclure le port :4443 car le HTTPS public passe par cet entrypoint Traefik.
DJANGO_SITE_DOMAIN=fitcoach.infotechno.eu:4443
DJANGO_SITE_NAME=FitCoach

# Origines de confiance pour la protection CSRF.
# ⚠️ Le HTTPS public passe par l'entrypoint Traefik :4443 (port non-standard) :
# l'origine envoyée par le navigateur inclut donc le port. Il DOIT figurer ici,
# sinon erreurs CSRF sur les formulaires.
DJANGO_CSRF_TRUSTED_ORIGINS=https://fitcoach.infotechno.eu:4443

# Sécurité HTTPS (Traefik termine le TLS et transmet X-Forwarded-Proto).
# Laissez ces valeurs telles quelles en prod ; mettez-les à False seulement
# pour tester en local sans certificat.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

# --- Base de données (PostgreSQL dans le conteneur "db") -----------------
POSTGRES_DB=fitcoach
POSTGRES_USER=fitcoach
POSTGRES_PASSWORD=remplacez-par-un-mot-de-passe-fort

# Alternative : URL unique (a priorité sur les POSTGRES_* ci-dessus si définie).
# DATABASE_URL=postgres://fitcoach:motdepasse@db:5432/fitcoach

# --- Redis (cache + sessions) --------------------------------------------
# Renseigné automatiquement par docker-compose.prod.yml (redis://redis:6379/0).
DJANGO_USE_REDIS=True

# --- API Anthropic (Claude) ---------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
